#include <stdio.h>
#include <string.h>

int main() {
    char files[20][20];
    int n = 0, choice, i;
    char fname[20];

    while(1) {
        printf("\n1. Create File\n2. Delete File\n3. Display Files\n4. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Enter file name: ");
                scanf("%s", fname);

                // Check duplicate
                for(i = 0; i < n; i++) {
                    if(strcmp(files[i], fname) == 0) {
                        printf("File already exists!\n");
                        break;
                    }
                }

                if(i == n) {
                    strcpy(files[n], fname);
                    n++;
                    printf("File created successfully\n");
                }
                break;

            case 2:
                printf("Enter file name to delete: ");
                scanf("%s", fname);

                for(i = 0; i < n; i++) {
                    if(strcmp(files[i], fname) == 0) {
                        for(int j = i; j < n-1; j++) {
                            strcpy(files[j], files[j+1]);
                        }
                        n--;
                        printf("File deleted successfully\n");
                        break;
                    }
                }

                if(i == n)
                    printf("File not found\n");
                break;

            case 3:
                printf("\nFiles in Directory:\n");
                for(i = 0; i < n; i++) {
                    printf("%s\n", files[i]);
                }
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice\n");
        }
    }

    return 0;
}
