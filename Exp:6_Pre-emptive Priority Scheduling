#include <stdio.h>
int main() {
    int n, i, time = 0, completed = 0, min_pr, shortest;
    int at[10], bt[10], rt[10], pr[10], ct[10], tat[10], wt[10];
    int is_completed[10] = {0};
    printf("Enter number of processes: ");
    scanf("%d", &n);
    for(i = 0; i < n; i++) {
        printf("P%d Arrival Time: ", i+1);
        scanf("%d", &at[i]);
        printf("P%d Burst Time: ", i+1);
        scanf("%d", &bt[i]);
        printf("P%d Priority: ", i+1);
        scanf("%d", &pr[i]);
        rt[i] = bt[i]; 
    }
    while(completed != n) {
        min_pr = 9999;
        shortest = -1;
        for(i = 0; i < n; i++) {
            if(at[i] <= time && is_completed[i] == 0) {
                if(pr[i] < min_pr) {
                    min_pr = pr[i];
                    shortest = i;
                }
            }
        }
        if(shortest == -1) {
            time++;
            continue;
        }
        rt[shortest]--;
        time++;
        if(rt[shortest] == 0) {
            ct[shortest] = time;
            is_completed[shortest] = 1;
            completed++;
        }
    }
    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
    }
    printf("\nProcess\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               i+1, at[i], bt[i], pr[i], ct[i], tat[i], wt[i]);
    }
    return 0;
}
