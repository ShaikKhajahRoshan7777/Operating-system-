#include <stdio.h>

void firstFit(int b[], int m, int p[], int n) {
    int i, j, alloc[10];

    for(i=0;i<n;i++) alloc[i] = -1;

    for(i=0;i<n;i++){
        for(j=0;j<m;j++){
            if(b[j] >= p[i]){
                alloc[i] = j;
                b[j] -= p[i];
                break;
            }
        }
    }

    printf("\nFIRST FIT\n");
    printf("Process\tSize\tBlock\n");
    for(i=0;i<n;i++){
        if(alloc[i] != -1)
            printf("P%d\t%d\tB%d\n", i+1, p[i], alloc[i]+1);
        else
            printf("P%d\t%d\tNot Allocated\n", i+1, p[i]);
    }
}

void bestFit(int b[], int m, int p[], int n) {
    int i, j, alloc[10], best;

    for(i=0;i<n;i++) alloc[i] = -1;

    for(i=0;i<n;i++){
        best = -1;
        for(j=0;j<m;j++){
            if(b[j] >= p[i]){
                if(best == -1 || b[j] < b[best])
                    best = j;
            }
        }
        if(best != -1){
            alloc[i] = best;
            b[best] -= p[i];
        }
    }

    printf("\nBEST FIT\n");
    printf("Process\tSize\tBlock\n");
    for(i=0;i<n;i++){
        if(alloc[i] != -1)
            printf("P%d\t%d\tB%d\n", i+1, p[i], alloc[i]+1);
        else
            printf("P%d\t%d\tNot Allocated\n", i+1, p[i]);
    }
}

void worstFit(int b[], int m, int p[], int n) {
    int i, j, alloc[10], worst;

    for(i=0;i<n;i++) alloc[i] = -1;

    for(i=0;i<n;i++){
        worst = -1;
        for(j=0;j<m;j++){
            if(b[j] >= p[i]){
                if(worst == -1 || b[j] > b[worst])
                    worst = j;
            }
        }
        if(worst != -1){
            alloc[i] = worst;
            b[worst] -= p[i];
        }
    }

    printf("\nWORST FIT\n");
    printf("Process\tSize\tBlock\n");
    for(i=0;i<n;i++){
        if(alloc[i] != -1)
            printf("P%d\t%d\tB%d\n", i+1, p[i], alloc[i]+1);
        else
            printf("P%d\t%d\tNot Allocated\n", i+1, p[i]);
    }
}

int main() {
    int m, n, i;
    int blocks[10], process[10];
    int b1[10], b2[10], b3[10];

    printf("Enter number of blocks: ");
    scanf("%d", &m);

    printf("Enter block sizes:\n");
    for(i=0;i<m;i++){
        scanf("%d", &blocks[i]);
        b1[i] = b2[i] = b3[i] = blocks[i]; // copy
    }

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter process sizes:\n");
    for(i=0;i<n;i++){
        scanf("%d", &process[i]);
    }

    firstFit(b1, m, process, n);
    bestFit(b2, m, process, n);
    worstFit(b3, m, process, n);

    return 0;
}
