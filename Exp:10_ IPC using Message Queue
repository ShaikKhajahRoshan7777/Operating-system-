#include <stdio.h>
#include <sys/ipc.h>
#include <sys/msg.h>
#include <string.h>
#include <unistd.h>

struct msg {
    long type;
    char text[100];
};

int main() {
    int msgid = msgget(IPC_PRIVATE, 0666 | IPC_CREAT);
    struct msg m;

    if (fork() == 0) {
        msgrcv(msgid, &m, sizeof(m.text), 1, 0);
        printf("\nProcess\tOperation\tMessage\n");
        printf("Child\tReceive\t\t%s\n", m.text);
    } else {
        m.type = 1;
        strcpy(m.text, "Hello");
        msgsnd(msgid, &m, sizeof(m.text), 0);
        printf("\nProcess\tOperation\tMessage\n");
        printf("Parent\tSend\t\t%s\n", m.text);
    }
}
